<UserControl x:Class="GD_ControlCenter_WPF.Views.Pages.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800"
             Background="{DynamicResource MaterialDesignPaper}"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12">
            <materialDesign:Card Padding="16" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="通信设置" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontSize="16" FontWeight="Bold"/>
                    <Separator Margin="0,6,0,12" Style="{StaticResource MaterialDesignLightSeparator}" />

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="串口号" VerticalAlignment="Center" Opacity="0.8" Margin="0,0,12,0" FontSize="14"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort, Mode=TwoWay}" materialDesign:HintAssist.Hint="未检测到串口" materialDesign:TextFieldAssist.UnderlineBrush="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" FontSize="14"/>
                        <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}" Command="{Binding RefreshPortsCommand}" ToolTip="刷新设备列表并尝试自动连接" Margin="8,0,0,0" Width="30" Height="30">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </Button>
                        <Button Grid.Column="3" Content="连接" Command="{Binding ConnectCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="16,0,0,0" Width="90" Height="30"/>
                        <TextBlock Grid.Column="4" Text="{Binding StatusText}" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.8" FontSize="14" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Padding="16" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="系统与数据配置" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontSize="16" FontWeight="Bold"/>
                    <Separator Margin="0,6,0,12" Style="{StaticResource MaterialDesignLightSeparator}" />

                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="异常熄火自动点火" FontSize="15" />
                            <TextBlock Text="检测到意外熄火时将自动触发重燃序列" FontSize="11" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding IsAutoReigniteEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}" ToolTip="开启或关闭熄火自动重燃" />
                    </Grid>

                    <Separator Margin="0,4,0,8" Style="{StaticResource MaterialDesignLightSeparator}" Opacity="0.3"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="光谱仪硬件连接使能" FontSize="15" />
                            <TextBlock Text="全局控制光谱仪的物理连接与数据交互权限" FontSize="11" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1" IsChecked="{Binding IsSpectrometerEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}" ToolTip="启用或断开光谱仪硬件连接" />
                    </Grid>

                    <Separator Margin="0,4,0,12" Style="{StaticResource MaterialDesignLightSeparator}" Opacity="0.3"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="单次保存默认路径" FontSize="15" />
                            <TextBlock Text="点击“单幅保存”生成的 Excel 文件位置" FontSize="11" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>

                        <TextBox Grid.Column="1" 
                                 Text="{Binding SingleSaveExportPath, Mode=OneWay}" 
                                 IsReadOnly="True"
                                 materialDesign:HintAssist.Hint="选择保存文件夹"
                                 materialDesign:TextFieldAssist.UnderlineBrush="{DynamicResource PrimaryHueMidBrush}"
                                 VerticalAlignment="Center" FontSize="13" Margin="0,0,12,0" Padding="0,0,0,4"/>

                        <Button Grid.Column="2" 
                                Content="浏览" 
                                Command="{Binding BrowseExportPathCommand}" 
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Width="90" Height="30"/>
                    </Grid>

                    <Separator Margin="0,8,0,12" Style="{StaticResource MaterialDesignLightSeparator}" Opacity="0.3"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="时序图自动保存目录" FontSize="15" />
                            <TextBlock Text="时序图任务结束时生成的 Excel 文件位置" FontSize="11" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>

                        <TextBox Grid.Column="1" 
                                 Text="{Binding TimeSeriesSaveDirectory, Mode=OneWay}" 
                                 IsReadOnly="True"
                                 materialDesign:HintAssist.Hint="选择保存文件夹"
                                 materialDesign:TextFieldAssist.UnderlineBrush="{DynamicResource PrimaryHueMidBrush}"
                                 VerticalAlignment="Center" FontSize="13" Margin="0,0,12,0" Padding="0,0,0,4"/>

                        <Button Grid.Column="2" 
                                Content="浏览" 
                                Command="{Binding BrowseTimeSeriesDirectoryCommand}" 
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Width="90" Height="30"/>
                    </Grid>

                    <Separator Margin="0,8,0,12" Style="{StaticResource MaterialDesignLightSeparator}" Opacity="0.3"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="点火持续时间 (秒)" FontSize="15" />
                            <TextBlock Text="设定单次点火指令的物理延时长度 (1.0 - 5.0s)" FontSize="11" Opacity="0.6" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox Text="{Binding IgnitionDelaySeconds, StringFormat={}{0:F1}, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="45" TextAlignment="Center" VerticalAlignment="Center" 
                                     FontSize="16" FontWeight="Bold" Margin="0,0,8,0"
                                     materialDesign:TextFieldAssist.UnderlineBrush="{DynamicResource PrimaryHueMidBrush}"/>

                            <StackPanel VerticalAlignment="Center">
                                <RepeatButton Command="{Binding IncreaseIgnitionDelayCommand}" 
                                              Style="{StaticResource MaterialDesignIconButton}" 
                                              Width="24" Height="24" Padding="0" ToolTip="增加">
                                    <materialDesign:PackIcon Kind="ChevronUp" Width="18" Height="18" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                </RepeatButton>
                                <RepeatButton Command="{Binding DecreaseIgnitionDelayCommand}" 
                                              Style="{StaticResource MaterialDesignIconButton}" 
                                              Width="24" Height="24" Padding="0" ToolTip="减少" Margin="0,2,0,0">
                                    <materialDesign:PackIcon Kind="ChevronDown" Width="18" Height="18" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                </RepeatButton>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>