<UserControl x:Class="GD_ControlCenter_WPF.Views.Pages.SampleMeasurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 三列核心布局 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <!-- 样品序列与配置 -->
                <ColumnDefinition Width="5.5*"/>
                <!-- 双图表区 -->
                <ColumnDefinition Width="2*"/>
                <!-- 测量结果计算区 -->
            </Grid.ColumnDefinitions>

            <!-- ================= 左侧：样本 (主) 与 元素 (辅) ================= -->
            <Grid Grid.Column="0" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Row="0" Margin="0,0,0,5" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text=" 样 品 序 列 " Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Opacity="0.8"/>
                        <Separator Margin="0,4,0,4" Style="{StaticResource MaterialDesignLightSeparator}"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding SampleSequence}" SelectedItem="{Binding SelectedSample, Mode=TwoWay}"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="测量中">
                                                    <Setter Property="Foreground" Value="Orange"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="完成">
                                                    <Setter Property="Foreground" Value="Green"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="名称" Binding="{Binding SampleName}" Width="*"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="1" Margin="0,5,0,0" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text=" 分 析 元 素 " Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Opacity="0.8"/>
                        <Separator Margin="0,4,0,4" Style="{StaticResource MaterialDesignLightSeparator}"/>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding ActiveConfigs}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="元素" Binding="{Binding ElementName}" Width="*"/>
                                <DataGridTextColumn Header="波长(nm)" Binding="{Binding Wavelength}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- ================= 中间：光谱图 (寻峰) 与 时序图 (记录) ================= -->
            <Grid Grid.Column="1" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Row="0" Margin="0,0,0,5" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text=" 实 时 光 谱 图 (右键寻峰)" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Opacity="0.8"/>
                        <Border Grid.Row="1" Background="Black" CornerRadius="8" Margin="0,4,0,0">
                            <!-- 光谱控件 -->
                            <ScottPlot:WpfPlot x:Name="SpectrumPlot" />
                        </Border>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="1" Margin="0,5,0,0" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text=" 强 度 时 序 图 (寻峰后动态映射)" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Opacity="0.8"/>
                        <Border Grid.Row="1" Background="Black" CornerRadius="8" Margin="0,4,0,0">
                            <!-- 时序控件 -->
                            <ScottPlot:WpfPlot x:Name="TimeSeriesPlot" />
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- ================= 右侧：当前样品结算结果 ================= -->
            <materialDesign:Card Grid.Column="2" Margin="5" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2" Background="{DynamicResource PrimaryHueLightBrush}" Foreground="{DynamicResource PrimaryHueLightForegroundBrush}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text=" 测 量 结 算 结 果 " FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="{Binding SelectedSample.SampleName, StringFormat='当前样品: {0}'}" Opacity="0.8" Margin="0,5,0,0"/>
                        <Separator Margin="0,8,0,8" Background="White" Opacity="0.3"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentSampleResults}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Background="Transparent" RowBackground="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="元素" Binding="{Binding ElementName}" Width="*"/>
                            <DataGridTextColumn Header="平均强度" Binding="{Binding AverageIntensity}" Width="1.5*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- ================= 底部：操作控制面板 ================= -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,10">
            <!-- 状态修改区 -->
            <Button Content="设为等待" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding MarkAsWaitingCommand}" Margin="0,0,10,0"/>
            <Button Content="设为完成" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding MarkAsCompletedCommand}" Margin="0,0,50,0"/>

            <!-- 核心流程区 -->
            <Button Content="{Binding MeasurementButtonText}" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding ToggleMeasurementCommand}" Width="150" Height="45" FontSize="18" Margin="0,0,20,0"/>
            <Button Content="暂停记录" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding TogglePauseCommand}" Background="Orange" BorderBrush="Orange" Width="120" Height="45" FontSize="16"/>
        </StackPanel>
    </Grid>
</UserControl>