<UserControl x:Class="GD_ControlCenter_WPF.Views.Pages.SampleMeasurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Margin="5,5,5,5" UniformCornerRadius="4" Background="{DynamicResource PrimaryHueLightBrush}" Foreground="{DynamicResource PrimaryHueLightForegroundBrush}">
            <TextBlock Text="{Binding CurrentSequenceStatus, FallbackValue='当前状态：等待测量'}" 
                       Margin="16,8" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
        </materialDesign:Card>

        <Grid Grid.Row="1" Margin="5,0,5,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Margin="0,0,0,2.5" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="分析配置" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Opacity="0.8"/>
                        <Separator Margin="0,4,0,0" Style="{StaticResource MaterialDesignLightSeparator}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ActiveConfigs}" 
                              AutoGenerateColumns="False" IsReadOnly="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              MaxHeight="200" Margin="0,8,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="元素" Binding="{Binding ElementName}" Width="*"/>
                            <DataGridTextColumn Header="波长 (nm)" Binding="{Binding Wavelength}" Width="*"/>
                            <DataGridTextColumn Header="拟合方程" Binding="{Binding EquationText}" Width="1.5*"/>
                            <DataGridTextColumn Header="R²" Binding="{Binding RSquaredText}" Width="*"/>
                            <DataGridTextColumn Header="电流 (mA)" Binding="{Binding CurrentConfigText}" Width="*"/>
                            <DataGridTextColumn Header="转速 (rpm)" Binding="{Binding SpeedConfigText}" Width="*"/>
                            <DataGridTextColumn Header="采样次数" Binding="{Binding SampleCountText}" Width="*"/>
                            <DataGridTextColumn Header="采样间隔 (s)" Binding="{Binding SampleIntervalText}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <Grid Grid.Row="1" Margin="0,2.5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="2.8*" />
                    <ColumnDefinition Width="3.2*" />
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0" Margin="0,0,2.5,0" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="实时光谱图" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Opacity="0.8"/>
                            <Separator Margin="0,4,0,8" Style="{StaticResource MaterialDesignLightSeparator}"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="Black" CornerRadius="8">
                            <ScottPlot:WpfPlot x:Name="RealTimePlot" />
                        </Border>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="1" Margin="2.5,0,2.5,0" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="待测样品" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Opacity="0.8"/>
                            <Separator Margin="0,4,0,0" Style="{StaticResource MaterialDesignLightSeparator}"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding SampleSequence}" 
                                  SelectedItem="{Binding SelectedSample, Mode=TwoWay}"
                                  AutoGenerateColumns="False" IsReadOnly="True" 
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  Margin="0,8,0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>

                                <DataGridTemplateColumn Header="平均强度" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding AverageIntensity}" VerticalAlignment="Center">
                                                <TextBlock.ToolTip>
                                                    <ToolTip Content="{Binding IntensityDetails}" 
                                                             Visibility="{Binding HasIntensityData, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" 
                                     materialDesign:HintAssist.Hint="样品名称" 
                                     Text="{Binding NewSampleName, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                     VerticalAlignment="Bottom"/>

                            <Button Grid.Column="1" 
                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}" 
                                    Command="{Binding AddSampleCommand}" 
                                    ToolTip="添加样品"
                                    Margin="16,0,0,0" VerticalAlignment="Bottom">
                                <materialDesign:PackIcon Kind="Plus" Width="24" Height="24"/>
                            </Button>
                        </Grid>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="2" Margin="2.5,0,0,0" UniformCornerRadius="8" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="测量结果" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Opacity="0.8" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedSample.Name, StringFormat=' - {0}'}" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Opacity="0.8" VerticalAlignment="Center"
                                           Visibility="{Binding SelectedSample, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                            <Separator Margin="0,4,0,0" Style="{StaticResource MaterialDesignLightSeparator}"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedSampleResults}" 
                                  AutoGenerateColumns="False" IsReadOnly="True" 
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="元素" Binding="{Binding ElementName}" Width="*"/>
                                <DataGridTextColumn Header="波长 (nm)" Binding="{Binding Wavelength}" Width="*"/>
                                <DataGridTextColumn Header="浓度" Binding="{Binding Concentration}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,15">
            <Button Content="移除序列" 
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Command="{Binding RemoveSampleCommand}" 
                    Margin="0,0,15,0"/>

            <Button Content="开始采样" 
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Command="{Binding StartSamplingCommand}" 
                    Margin="0,0,15,0"/>

            <Button Content="停止采样" 
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Command="{Binding StopSamplingCommand}" 
                    Margin="0,0,15,0"/>
        </StackPanel>
    </Grid>
</UserControl>