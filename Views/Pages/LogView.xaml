<UserControl x:Class="GD_ControlCenter_WPF.Views.Pages.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GD_ControlCenter_WPF.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#F5F5F5">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="运行日志 (System Logs)" FontSize="32" FontWeight="Bold"/>
            <TextBlock Text="此处将显示设备运行状态与历史记录" HorizontalAlignment="Center" Margin="0,10" Opacity="0.6"/>
        </StackPanel>
    </Grid>
</UserControl>
