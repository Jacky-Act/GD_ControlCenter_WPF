<UserControl x:Class="GD_ControlCenter_WPF.Views.Pages.DataProcessingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <materialDesign:PackIcon Kind="DatabaseSearch" Width="100" Height="100" 
                                    Foreground="{DynamicResource PrimaryHueMidBrush}" Opacity="0.3"/>
            <TextBlock Text="数据处理与分析" FontSize="28" FontWeight="Bold" Margin="0,20" Opacity="0.5"/>
            <TextBlock Text="该模块将用于处理实验历史数据与寻峰计算。" FontSize="16" Opacity="0.4"/>
        </StackPanel>
    </Grid>
</UserControl>