<UserControl x:Class="GD_ControlCenter_WPF.Views.Pages.SampleSequenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 顶栏文件流 -->
            <RowDefinition Height="Auto"/>
            <!-- 批量操作区 -->
            <RowDefinition Height="*"/>
            <!-- 大表格 -->
            <RowDefinition Height="Auto"/>
            <!-- 底部应用 -->
        </Grid.RowDefinitions>

        <!-- 1. 顶栏：序列模板与导入导出 -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,10" UniformCornerRadius="6" materialDesign:ElevationAssist.Elevation="Dp1">
            <StackPanel Orientation="Horizontal" Margin="10,5">
                <materialDesign:PackIcon Kind="FolderOpenOutline" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Width="150" materialDesign:HintAssist.Hint="读取本地序列模板" ItemsSource="{Binding SavedTemplates}" SelectedItem="{Binding SelectedTemplate}" Margin="0,0,10,0"/>
                <Button Content="加载" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding LoadTemplateCommand}" Margin="0,0,30,0" Height="30"/>

                <TextBox Width="150" materialDesign:HintAssist.Hint="另存为新模板名称" Text="{Binding NewTemplateName}" Margin="0,0,10,0"/>
                <Button Content="保存模板" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding SaveTemplateCommand}" Margin="0,0,30,0" Height="30"/>

                <Separator Style="{StaticResource MaterialDesignLightSeparator}" Width="2" Height="30" Margin="0,0,30,0">
                    <Separator.LayoutTransform>
                        <RotateTransform Angle="90"/>
                    </Separator.LayoutTransform>
                </Separator>

                <Button Content="导入 CSV" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0" Height="30"/>
                <Button Content="导出 CSV" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ExportCsvCommand}" Height="30"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- 2. 批量生成模块 -->
        <materialDesign:Card Grid.Row="1" Margin="0,0,0,10" UniformCornerRadius="6" materialDesign:ElevationAssist.Elevation="Dp1" Background="#F3F4F6">
            <StackPanel Orientation="Horizontal" Margin="15,10">
                <TextBlock Text="批量快捷建表：" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <TextBlock Text="标准样品数量:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Width="50" Text="{Binding BatchStandardCount}" TextAlignment="Center" Margin="0,0,20,0"/>

                <TextBlock Text="待测样品数量:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Width="50" Text="{Binding BatchUnknownCount}" TextAlignment="Center" Margin="0,0,20,0"/>

                <Button Content="一键生成新序列" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding BatchGenerateCommand}" Height="30"/>
                <TextBlock Text="(此操作将清空当前表格)" VerticalAlignment="Center" Opacity="0.5" Margin="10,0,0,0"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- 3. 数据表格 (支持动态列注入) -->
        <DataGrid x:Name="SequenceDataGrid" Grid.Row="2" ItemsSource="{Binding Samples}" SelectedItem="{Binding SelectedSample, Mode=TwoWay}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserSortColumns="False" materialDesign:DataGridAssist.CellPadding="12,8">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="删除选中行" Command="{Binding DeleteRowCommand}" Foreground="IndianRed"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <!-- 基础列：名称、类型、重复次数 -->
                <DataGridTextColumn Header="样品名称" Binding="{Binding SampleName, UpdateSourceTrigger=PropertyChanged}" Width="1.5*"/>
                <DataGridTemplateColumn Header="样品类型" Width="1*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.SampleTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="重复次数" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.AvailableRepeats, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding Repeats, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" IsReadOnly="True" Width="80"/>

                <!-- 动态浓度列将由后台 C# 代码在此处自动注入 -->

            </DataGrid.Columns>
        </DataGrid>

        <!-- 4. 底部应用 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="追加空白行" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding AddRowCommand}" Margin="0,0,10,0"/>
            <Button Content="应用当前序列至测量库" Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding ApplySequenceCommand}" Width="200"/>
        </StackPanel>
    </Grid>
</UserControl>