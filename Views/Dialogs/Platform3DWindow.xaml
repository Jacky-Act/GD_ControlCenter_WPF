<Window x:Class="GD_ControlCenter_WPF.Views.Dialogs.Platform3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="三维平台控制" Height="260" Width="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Window.Resources>
        <SolidColorBrush x:Key="PurpleThemeBrush" Color="#673ab7" />

        <Style x:Key="PurpleRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource PurpleThemeBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="实时坐标监测" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" Margin="0,0,0,12"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="X" FontWeight="Bold" FontSize="18" VerticalAlignment="Bottom" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CurrentX, StringFormat={}{0:F0}}" FontSize="20" FontWeight="Bold" Foreground="Black" VerticalAlignment="Bottom"/>
                    <TextBlock Text="{Binding MaxX, StringFormat=/{0:F0}}" FontSize="12" Opacity="0.6" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Y" FontWeight="Bold" FontSize="18" VerticalAlignment="Bottom" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CurrentY, StringFormat={}{0:F0}}" FontSize="20" FontWeight="Bold" Foreground="Black" VerticalAlignment="Bottom"/>
                    <TextBlock Text="{Binding MaxY, StringFormat=/{0:F0}}" FontSize="12" Opacity="0.6" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <TextBlock Text="Z" FontWeight="Bold" FontSize="18" VerticalAlignment="Bottom" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding CurrentZ, StringFormat={}{0:F0}}" FontSize="20" FontWeight="Bold" Foreground="Black" VerticalAlignment="Bottom"/>
                    <TextBlock Text="{Binding MaxZ, StringFormat=/{0:F0}}" FontSize="12" Opacity="0.6" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Top">
            <TextBlock Text="自动化校准序列" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" Margin="0,0,0,12"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0" ItemsSource="{Binding PeakWavelengths}" 
                          SelectedItem="{Binding SelectedPeakWavelength}"
                          materialDesign:HintAssist.Hint="目标波长 (nm)"
                          HorizontalAlignment="Stretch" Margin="0,0,15,0" VerticalAlignment="Center"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>

                <Button Grid.Column="1" Command="{Binding StartCalibrationCommand}" 
                        Content="开始校准" 
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource PurpleThemeBrush}"
                        BorderBrush="{StaticResource PurpleThemeBrush}"
                        IsEnabled="{Binding !IsCalibrating}"
                        Width="100" Height="36" materialDesign:ButtonAssist.CornerRadius="4"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <materialDesign:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0.7"/>
                <TextBlock Text="{Binding CalibrationStatus}" VerticalAlignment="Center" FontSize="11" Opacity="0.8" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <TextBlock Text="手动步进调节" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" Margin="0,0,0,10"/>

            <Grid Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#10000000" CornerRadius="6" Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="X轴" GroupName="AxisGroup" IsChecked="True" Style="{StaticResource PurpleRadioButtonStyle}" Width="65" />
                        <RadioButton Content="Y轴" GroupName="AxisGroup" Style="{StaticResource PurpleRadioButtonStyle}" Width="65"/>
                        <RadioButton Content="Z轴" GroupName="AxisGroup" Style="{StaticResource PurpleRadioButtonStyle}" Width="65"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#10000000" CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="{materialDesign:PackIcon Kind=Plus}" ToolTip="正向移动" GroupName="DirGroup" IsChecked="True" Style="{StaticResource PurpleRadioButtonStyle}" Width="65"/>
                        <RadioButton Content="{materialDesign:PackIcon Kind=Minus}" ToolTip="反向移动" GroupName="DirGroup" Style="{StaticResource PurpleRadioButtonStyle}" Width="65"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,15,0" VerticalAlignment="Center">
                    <TextBlock Text="步长" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" Opacity="0.8"/>
                    <TextBox Text="{Binding StepDistance, UpdateSourceTrigger=PropertyChanged}" 
                             Width="80" 
                             TextAlignment="Center" VerticalAlignment="Center"
                             Style="{StaticResource MaterialDesignTextBox}"/>
                </StackPanel>

                <Button Grid.Column="4" Command="{Binding MoveCommand}" Style="{StaticResource MaterialDesignRaisedButton}" 
                        Background="{StaticResource PurpleThemeBrush}"
                        BorderBrush="{StaticResource PurpleThemeBrush}"
                        Content="移动" Width="100" Height="36" materialDesign:ButtonAssist.CornerRadius="4"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>