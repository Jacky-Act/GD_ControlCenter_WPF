<Window x:Class="GD_ControlCenter_WPF.Views.Dialogs.ScriptSaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="自动化脚本保存配置" 
        Height="460" Width="440"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,0">
            <TextBlock Text="自动化脚本保存配置" Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
            <Separator Margin="0,8,0,0" Style="{StaticResource MaterialDesignLightSeparator}" />
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="10,0,10,0" IsEnabled="{Binding IsNotSaving}">

            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="保存总次数" FontSize="14" Opacity="0.7" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <RepeatButton Grid.Column="0" Command="{Binding DecreaseCountCommand}" 
                                  Content="-" FontSize="24" Width="48" Height="40" Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <TextBox Grid.Column="1" Text="{Binding ScriptSaveCount, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="18" TextAlignment="Center" VerticalAlignment="Center" Margin="16,0"/>
                    <RepeatButton Grid.Column="2" Command="{Binding IncreaseCountCommand}" 
                                  Content="+" FontSize="24" Width="48" Height="40" Style="{StaticResource MaterialDesignOutlinedButton}" />
                </Grid>
            </StackPanel>

            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="保存间隔 (秒)" FontSize="14" Opacity="0.7" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <RepeatButton Grid.Column="0" Command="{Binding DecreaseIntervalCommand}" 
                                  Content="-" FontSize="24" Width="48" Height="40" Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <TextBox Grid.Column="1" Text="{Binding ScriptSaveInterval, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="18" TextAlignment="Center" VerticalAlignment="Center" Margin="16,0"/>
                    <RepeatButton Grid.Column="2" Command="{Binding IncreaseIntervalCommand}" 
                                  Content="+" FontSize="24" Width="48" Height="40" Style="{StaticResource MaterialDesignOutlinedButton}" />
                </Grid>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="存储目录" FontSize="14" Opacity="0.7" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ScriptSaveDirectory, Mode=OneWay}" IsReadOnly="True"
                             materialDesign:HintAssist.Hint="选择存放文件夹"
                             materialDesign:TextFieldAssist.UnderlineBrush="{DynamicResource PrimaryHueMidBrush}"
                             VerticalAlignment="Center" FontSize="14" Margin="0,0,16,0"/>
                    <Button Grid.Column="1" Content="浏览..." Command="{Binding BrowseDirectoryCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="32"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Button HorizontalAlignment="Left" 
                    Content="{Binding ToggleBtnText}" 
                    Command="{Binding ToggleSaveCommand}"
                    Background="{Binding ToggleBtnColor}"
                    BorderBrush="{Binding ToggleBtnColor}"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Width="110"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0" Width="90"/>
                <Button Content="应用" Command="{Binding ApplyCommand}" IsEnabled="{Binding IsNotSaving}" Style="{StaticResource MaterialDesignRaisedButton}" Width="90"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>