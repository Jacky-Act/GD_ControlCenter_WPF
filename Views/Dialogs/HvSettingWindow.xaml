<Window x:Class="GD_ControlCenter_WPF.Views.Dialogs.HvSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="高压电源参数设置" 
        Height="350" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,0">
            <TextBlock Text="参数配置 - 高压电源" Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
            <Separator Margin="0,8,0,0" Style="{StaticResource MaterialDesignLightSeparator}" />
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">

            <TextBlock Text="设定电压 (0-1500)" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" Margin="0,0,0,2"/>
            <Grid Margin="0,5,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Slider Minimum="0" Maximum="1500" Margin="15,0,0,0"
                        Value="{Binding TargetVoltage, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource MaterialDesign3.MaterialDesignDiscreteSlider}"
                        VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center" MinWidth="80">
                    <TextBox Text="{Binding TargetVoltage, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="26" 
                             FontWeight="Bold"
                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                             BorderThickness="0" 
                             Background="Transparent"
                             TextAlignment="Center"
                             VerticalAlignment="Center"
                             InputScope="Number"
                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                             materialDesign:TextFieldAssist.TextBoxViewMargin="0" />
                    <Border Height="2" Background="{DynamicResource PrimaryHueMidBrush}" Opacity="0.4" Margin="5,2,5,0"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="设置电流 (0-100)" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" Margin="0,0,0,2"/>
            <Grid Margin="0,5,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Slider Minimum="0" Maximum="100" Margin="15,0,0,0"
                        Value="{Binding TargetCurrent, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource MaterialDesign3.MaterialDesignDiscreteSlider}"
                        VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center" MinWidth="80">
                    <TextBox Text="{Binding TargetCurrent, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="26" 
                             FontWeight="Bold"
                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                             BorderThickness="0" 
                             Background="Transparent"
                             TextAlignment="Center"
                             VerticalAlignment="Center"
                             InputScope="Number"
                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                             materialDesign:TextFieldAssist.TextBoxViewMargin="0" />
                    <Border Height="2" Background="{DynamicResource PrimaryHueMidBrush}" Opacity="0.4" Margin="5,2,5,0"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0" Width="100" />
            <Button Content="应用" Command="{Binding ApplyCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="100" />
        </StackPanel>
    </Grid>
</Window>