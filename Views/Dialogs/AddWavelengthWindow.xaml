<Window x:Class="GD_ControlCenter_WPF.Views.Dialogs.AddWavelengthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="添加特征波长" Height="200" Width="300" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBox Width="180" FontSize="16"
                     materialDesign:HintAssist.Hint="输入特征波长" 
                     Text="{Binding WavelengthValue, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
            <TextBlock Text="nm" FontSize="16" VerticalAlignment="Bottom" Margin="10,0,0,5" 
                       Foreground="{DynamicResource MaterialDesignBody}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Style="{StaticResource MaterialDesignOutlinedButton}" 
                    Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
            <Button Content="确认" Style="{StaticResource MaterialDesignRaisedButton}" 
                    Command="{Binding ApplyCommand}"/>
        </StackPanel>
    </Grid>
</Window>