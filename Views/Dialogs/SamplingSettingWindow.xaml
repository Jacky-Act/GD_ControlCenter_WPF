<Window x:Class="GD_ControlCenter_WPF.Views.Dialogs.SamplingSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="采样参数设置" 
        Height="350" Width="420"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,0">
            <TextBlock Text="参数配置 - 采样" Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
            <Separator Margin="0,8,0,0" Style="{StaticResource MaterialDesignLightSeparator}" />
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="30,0,30,0">

            <materialDesign:NumericUpDown Value="{Binding SampleCount, UpdateSourceTrigger=PropertyChanged}" 
                                          materialDesign:HintAssist.Hint="采样次数"
                                          materialDesign:HintAssist.IsFloating="True"
                                          Minimum="1" Maximum="10000"
                                          Margin="0,0,0,40" 
                                          FontSize="18"/>

            <materialDesign:NumericUpDown Value="{Binding SampleInterval, UpdateSourceTrigger=PropertyChanged}" 
                                          materialDesign:HintAssist.Hint="采样间隔 (s)"
                                          materialDesign:HintAssist.IsFloating="True"
                                          Minimum="0" Maximum="3600"
                                          FontSize="18"/>

        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0" Width="100"/>
            <Button Content="应用" Command="{Binding ApplyCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
