<Window x:Class="GD_ControlCenter_WPF.Views.Dialogs.SamplingSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="采样参数设置" 
        Height="350" Width="420"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,0">
            <TextBlock Text="参数配置 - 采样" Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
            <Separator Margin="0,8,0,0" Style="{StaticResource MaterialDesignLightSeparator}" />
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="30,0,30,0">

            <StackPanel Margin="0,0,0,30">
                <TextBlock Text="采样次数" FontSize="14" Opacity="0.7" 
                           Margin="0,0,0,8" HorizontalAlignment="Left"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <RepeatButton Grid.Column="0" Command="{Binding DecreaseSampleCountCommand}" 
                                  Content="-" FontSize="24" Width="48" Height="40" 
                                  Style="{StaticResource MaterialDesignOutlinedButton}" />

                    <TextBox Grid.Column="1" Text="{Binding SampleCount, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="18" TextAlignment="Center" VerticalAlignment="Center" Margin="16,0"/>

                    <RepeatButton Grid.Column="2" Command="{Binding IncreaseSampleCountCommand}" 
                                  Content="+" FontSize="24" Width="48" Height="40" 
                                  Style="{StaticResource MaterialDesignOutlinedButton}" />
                </Grid>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="采样间隔 (s)" FontSize="14" Opacity="0.7" 
                           Margin="0,0,0,8" HorizontalAlignment="Left"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <RepeatButton Grid.Column="0" Command="{Binding DecreaseSampleIntervalCommand}" 
                                  Content="-" FontSize="24" Width="48" Height="40" 
                                  Style="{StaticResource MaterialDesignOutlinedButton}" />

                    <TextBox Grid.Column="1" Text="{Binding SampleInterval, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="18" TextAlignment="Center" VerticalAlignment="Center" Margin="16,0"/>

                    <RepeatButton Grid.Column="2" Command="{Binding IncreaseSampleIntervalCommand}" 
                                  Content="+" FontSize="24" Width="48" Height="40" 
                                  Style="{StaticResource MaterialDesignOutlinedButton}" />
                </Grid>
            </StackPanel>

        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" IsCancel="True" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0" Width="100"/>
            <Button Content="应用" Command="{Binding ApplyCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="100"/>
        </StackPanel>
    </Grid>
</Window>